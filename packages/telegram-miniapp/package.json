{
  "name": "@storacha/telegram-miniapp",
  "version": "1.0.0",
  "description": "Telegram Mini App for encrypted chat backup using Storacha decentralized storage",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "tsx watch src/server/index.ts",
    "dev:miniapp": "vite src/miniapp",
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:miniapp\"",
    "build:server": "tsc -p tsconfig.server.json",
    "build:miniapp": "vite build src/miniapp",
    "build": "pnpm build:server && pnpm build:miniapp",
    "start": "node dist/server/index.js",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run"
  },
  "dependencies": {
    "@storacha/client": "workspace:^",
    "@storacha/capabilities": "workspace:^",
    "@ucanto/core": "catalog:",
    "@ucanto/principal": "catalog:",
    "express": "^4.18.2",
    "grammy": "^1.21.1",
    "grammy-types": "^3.9.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "crypto-js": "^4.2.0",
    "better-sqlite3": "^9.4.3",
    "dotenv": "^16.4.1",
    "multiformats": "catalog:",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.2",
    "@types/better-sqlite3": "^7.6.8",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "tsx": "^4.7.0",
    "vite": "^5.1.0",
    "vitest": "^1.3.1",
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  }
}
