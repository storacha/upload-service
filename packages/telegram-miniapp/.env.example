# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here
TELEGRAM_APP_URL=https://your-app.example.com

# Server Configuration
PORT=3000
NODE_ENV=development

# Storacha Configuration
STORACHA_SERVICE_URL=https://up.storacha.network
STORACHA_GATEWAY_URL=https://w3s.link

# Humanode BotBasher (Anti-bot)
HUMANODE_API_KEY=your_humanode_api_key_here
HUMANODE_OAUTH_CLIENT_ID=your_client_id_here

# Database
DATABASE_PATH=./data/telegram-backup.db

# Security
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_32_char_encryption_key_here
